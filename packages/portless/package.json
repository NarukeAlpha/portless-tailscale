{
  "name": "pless",
  "version": "0.12.0",
  "description": "Tailscale-first devbox gateway for stable local development URLs.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "pless": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "prepublishOnly": "cp ../../README.md . && pnpm build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "local",
    "development",
    "proxy",
    "localhost",
    "tailscale"
  ],
  "author": "Gabriel Alfonzo",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/NarukeAlpha/portless-tailscale.git"
  },
  "bugs": {
    "url": "https://github.com/NarukeAlpha/portless-tailscale/issues"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
